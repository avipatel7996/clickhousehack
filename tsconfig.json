{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["packages/core/src/*"],
      "@clickhouse/*": ["packages/clickhouse/src/*"],
      "@ingestion/*": ["packages/ingestion/src/*"],
      "@analysis/*": ["packages/analysis/src/*"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "trigger/**/*.ts", "next-env.d.ts"],
  "exclude": ["node_modules"]
}
